# --- Supabase Configuration ---
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase database password
SUPABASE_PASSWORD=your_password_here

# Service Role Key (server-side only, NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Database Connection (Supabase Pooler) ---
# Connection details from Supabase "Connect" screen
SUPABASE_DB_HOST=aws-1-sa-east-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.your_project_id
SUPABASE_DB_NAME=postgres

# --- API Configuration ---
API_HOST=127.0.0.1
API_PORT=8002
API_TOKEN=your_api_token_here

# --- Web Scraping Configuration ---
# Set to "true" to run Chrome in headless mode
SGUCARD_HEADLESS=false

# Chrome driver persistence
PERSISTENT_CHROME=true
IDLE_SHUTDOWN_MINUTES=30

# Login credentials for the web scraping target
SGUCARD_LOGIN=your_login_here
SGUCARD_PASSWORD=your_password_here

# --- Worker Configuration ---
# Comma-separated list of worker server URLs
SERVER_URLS=http://127.0.0.1:8000,http://127.0.0.1:8001,http://127.0.0.1:8002

# Health check settings
HEALTHCHECK_CACHE_SECONDS=5
HEALTHCHECK_TIMEOUT_SECONDS=5
HEALTHCHECK_PATH=/

# Dispatcher settings
DISPATCH_STAGGER_SECONDS=15
